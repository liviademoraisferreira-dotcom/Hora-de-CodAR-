programa {
  funcao inicio() {
    
    inteiro numero1
    inteiro numero2

    escreva ("informe o primeiro nuúmero: ")
    leia (numero1)

    escreva ("informe o segundo número: ")
    leia (numero2)

    se (numero1 > numero2) {
      escreva ("O maior número entre eles é" + numero1)
    }
    
    senao {
    escreva("O maior número entre eles é o: " + numero2)
    }
    
  }
}
